Algoritmo "semnome"

Var
contador : real


Inicio
enquanto   ( VERDADEIRO ) faca
    escreval ("oi")
     interrompa

fimEnquanto

enquanto (contador < 100) faca
 escreval (contador + 1)
se (contador = 100) entao
 escreval("limite máximo!")
 interrompa
      fimSe
      contador <- contador + 1
      fimEnquanto
      escreval("olha a repetiçăo")
Fimalgoritmo