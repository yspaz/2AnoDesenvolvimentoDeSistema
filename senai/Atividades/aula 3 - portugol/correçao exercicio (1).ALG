Algoritmo "correÓao do exercicio 1= 05/02/26"

Var
base , altura , area :real

Inicio
// trecho para coletar as medidas
escreval ("escreva a medida da base:")
leia (base)
escreval("escreva a medida da altura:")
leia (altura)
//trecho para calcular
 area <- base * altura
 
 
 //trecho para mostra resultado
 escreval("o resultado da area e:",area)
 
 
Fimalgoritmo